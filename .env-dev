# # collection configuration
COLLECTION_NAME="test"


# # client configuration
API_KEY="<YOUR_API_KEY>"
PORT=6336
HTTPS=False
PREFER_GRPC=True
GRPC_PORT=6337
HOST="localhost"
TIMEOUT=1000


# # duckdb configuration
DATABASE_NAME="DuckDB"


# # s3 configuration
AWS_ACCESS_KEY_ID="<YOUR_ACCESS_KEY_ID>"
AWS_SECRET_ACCESS_KEY="<YOUR_SECRET_ACCESS_KEY>"
AWS_BUCKET_NAME="vexor"
AWS_FILE_NAME="delta"
AWS_DOCUMENT_NAME="PCM"
AWS_ENDPOINT_URL="http://localhost:9000"
AWS_REGION="local"

# # genai configuration
GENAI_PLATFORM_NAME="<YOUR_GENAI_PLATFORM_NAME>"  # like "OpenAI"
GENAI_PROVIDER="crewai"
GENAI_API_KEY="<YOUR_GENAI_API_KEY>"
GENAI_LLM_MODEL_NAME="gpt-4"  # or "gpt-3.5-turbo"
GENAI_LLM_TEMPERATURE=0.7


# # embedding configuration
DENSE_EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
SPARSE_EMBEDDING_MODEL_NAME="prithivida/Splade_PP_en_v1"
EMBEDDING_CACHE_DIR="<YOUR_CACHE_DIR>"
EMBEDDING_THREAD=1 # embedding thread count


# # chunking configuration
CHUNKING_METHOD="Fast"
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_CHARACTERS_PER_CHUNK=50
MIN_SENTENCES_PER_CHUNK=3


# # extra configuration
DATA_DIR="<YOUR_DATA_DIR>"
DATA_TYPE="tabular"
IS_TRAIN=True
BATCH_SIZE=128
IS_RECREATE_COLLECTION=True
DATA_UPLOAD_METHOD_INTO_COLLECTION="upsert"
PARALLEL_THREAD=1


# # indexing configuration
INDEXING_THRESHOLD=100000
M=16
ON_DISK=False
EF_CONSTRUCT=100

# # logging configuration
IS_LOG_ACTIVE=True
IS_LOG_PROD=False
IS_LOG_TO_FILE=False


# # tracing configuration
TRACING_PLATFORM_NAME="Opik"
TRACING_PROJECT_NAME="vexor"
TRACING_AGENTOPS_API_KEY="<YOUR_AGENTOPS_API_KEY>"
TRACING_OPIK_API_KEY="<YOUR_OPIK_API_KEY>"
TRACING_LANGFUSE_SECRET_KEY="<YOUR_LANGFUSE_SECRET_KEY>"
TRACING_LANGFUSE_PUBLIC_KEY="<YOUR_LANGFUSE_PUBLIC_KEY>"
TRACING_LANGFUSE_HOST="https://cloud.langfuse.com"
